---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<p class="footer-copy">&copy; {today.getFullYear()} Test Blog</p>
		<p class="footer-copy">For ophthalmic use only.</p>
	</div>
</footer>
<style>
	footer {
		padding: 3em 1em;
		background: var(--bg);
		border-top: 1px solid var(--border-color);
		margin-top: 6em;
	}
	.footer-inner {
		max-width: 720px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.footer-copy {
		margin: 0;
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
		font-size: 0.85em;
		color: rgb(var(--gray));
		letter-spacing: 0.01em;
	}
</style>
