---
import { SITE_TITLE, NAV_BLOG, NAV_ABOUT } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="site-title">{SITE_TITLE}</a>
		<div class="nav-links">
			<HeaderLink href="/blog">{NAV_BLOG}</HeaderLink>
			<HeaderLink href="/about">{NAV_ABOUT}</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1.5em;
		background: var(--bg);
		border-bottom: 1px solid var(--border-color);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
		height: 60px;
	}
	.site-title {
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
		font-size: 0.95em;
		font-weight: 600;
		letter-spacing: -0.01em;
		color: rgb(var(--black));
		text-decoration: none;
		border-bottom: none;
	}
	.site-title:hover {
		color: var(--accent);
		border-bottom: none;
	}
	.nav-links {
		display: flex;
		gap: 0.25em;
	}
	.nav-links :global(a) {
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
		font-size: 0.875em;
		padding: 0.5em 0.875em;
		color: rgb(var(--gray));
		text-decoration: none;
		border-bottom: none;
		border-radius: 6px;
		transition: color 0.15s ease, background 0.15s ease;
		letter-spacing: 0.01em;
	}
	.nav-links :global(a:hover) {
		color: rgb(var(--black));
		background: rgb(var(--gray-light));
		border-bottom: none;
	}
	.nav-links :global(a.active) {
		color: rgb(var(--black));
		font-weight: 500;
	}
</style>
