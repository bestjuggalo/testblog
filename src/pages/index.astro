---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE, HERO_EYEBROW, HERO_HEADING, HERO_DESCRIPTION, HERO_CTA } from '../consts';

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>

			<!-- Hero -->
			<section class="hero">
				<p class="hero-eyebrow">{HERO_EYEBROW}</p>
				<h1 class="hero-heading" set:html={HERO_HEADING.replace('\n', '<br />')}></h1>
				<p class="hero-description">{HERO_DESCRIPTION}</p>
				<a href="/blog" class="hero-cta">{HERO_CTA}</a>
			</section>

			<hr class="section-divider" />

			<!-- Featured post (most recent) -->
			{posts.length > 0 && (
				<section class="featured-section">
					<span class="section-label">Latest</span>
					<a href={`/blog/${posts[0].id}/`} class="featured-post">
						<div class="featured-meta">
							<FormattedDate date={posts[0].data.pubDate} />
						</div>
						<h2 class="featured-title">{posts[0].data.title}</h2>
						{posts[0].data.description && (
							<p class="featured-description">{posts[0].data.description}</p>
						)}
						<span class="read-link">Read essay →</span>
					</a>
				</section>
			)}

			<hr class="section-divider" />

			<!-- Recent posts list -->
			{posts.length > 1 && (
				<section class="recent-section">
					<span class="section-label">Recent writing</span>
					<ol class="posts-list">
						{posts.slice(1).map((post) => (
							<li class="post-row">
								<a href={`/blog/${post.id}/`}>
									<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
									<span class="post-title">{post.data.title}</span>
								</a>
							</li>
						))}
					</ol>
					<a href="/blog" class="all-posts-link">All posts →</a>
				</section>
			)}

		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: calc(100% - 2em);
		max-width: 680px;
		padding-top: 5em;
		padding-bottom: 5em;
	}

	/* Hero */
	.hero {
		margin-bottom: 0;
	}
	.hero-eyebrow {
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
		font-size: 0.8em;
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--accent);
		margin: 0 0 1.25em 0;
		border-bottom: none;
	}
	.hero-heading {
		font-size: 3.25em;
		font-weight: 700;
		letter-spacing: -0.04em;
		line-height: 1.05;
		color: rgb(var(--black));
		margin: 0 0 0.6em 0;
	}
	.hero-description {
		font-size: 1.05em;
		color: rgb(var(--gray));
		line-height: 1.7;
		margin: 0 0 1.75em 0;
		max-width: 520px;
	}
	.hero-cta {
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
		font-size: 0.9em;
		font-weight: 500;
		color: rgb(var(--black));
		text-decoration: none;
		border-bottom: 1px solid rgb(var(--gray));
		padding-bottom: 1px;
		transition: color 0.15s ease, border-color 0.15s ease;
	}
	.hero-cta:hover {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}

	/* Dividers */
	.section-divider {
		border: none;
		border-top: 1px solid var(--border-color);
		margin: 4em 0;
	}

	/* Section label */
	.section-label {
		display: block;
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
		font-size: 0.75em;
		font-weight: 600;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: rgb(var(--gray));
		margin-bottom: 1.75em;
	}

	/* Featured post */
	.featured-post {
		display: block;
		text-decoration: none;
		border-bottom: none;
		color: inherit;
	}
	.featured-post:hover .featured-title {
		color: var(--accent);
	}
	.featured-meta {
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
		font-size: 0.82em;
		color: rgb(var(--gray));
		margin-bottom: 0.6em;
		letter-spacing: 0.01em;
	}
	.featured-title {
		font-size: 1.75em;
		font-weight: 700;
		letter-spacing: -0.03em;
		color: rgb(var(--black));
		margin: 0 0 0.6em 0;
		transition: color 0.15s ease;
	}
	.featured-description {
		font-size: 0.975em;
		color: rgb(var(--gray));
		line-height: 1.65;
		margin: 0 0 1.25em 0;
		max-width: 560px;
	}
	.read-link {
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
		font-size: 0.85em;
		font-weight: 500;
		color: var(--accent);
	}

	/* Posts list */
	.posts-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.post-row {
		border-bottom: 1px solid var(--border-color);
	}
	.post-row:first-child {
		border-top: 1px solid var(--border-color);
	}
	.post-row a {
		display: flex;
		align-items: baseline;
		gap: 1.5em;
		padding: 1.1em 0;
		text-decoration: none;
		border-bottom: none;
		color: inherit;
		transition: color 0.15s ease;
	}
	.post-row a:hover .post-title {
		color: var(--accent);
	}
	.post-date {
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
		font-size: 0.8em;
		color: rgb(var(--gray));
		white-space: nowrap;
		flex-shrink: 0;
		letter-spacing: 0.01em;
		min-width: 110px;
	}
	.post-title {
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
		font-size: 0.95em;
		font-weight: 500;
		color: rgb(var(--black));
		transition: color 0.15s ease;
	}
	.all-posts-link {
		display: inline-block;
		margin-top: 1.75em;
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
		font-size: 0.875em;
		font-weight: 500;
		color: rgb(var(--black));
		border-bottom: 1px solid rgb(var(--gray));
		text-decoration: none;
		padding-bottom: 1px;
		transition: color 0.15s ease, border-color 0.15s ease;
	}
	.all-posts-link:hover {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}

	@media (max-width: 720px) {
		main {
			padding-top: 3em;
			padding-bottom: 3em;
		}
		.hero-heading {
			font-size: 2.25em;
		}
		.hero-description {
			max-width: 100%;
		}
		.post-row a {
			flex-direction: column;
			gap: 0.2em;
		}
		.post-date {
			min-width: unset;
		}
	}
</style>
